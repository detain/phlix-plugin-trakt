{
    "name": "phlix-plugin-trakt",
    "version": "1.1.0",
    "phlix_min_server_version": "0.14.0",
    "type": "scrobbler",
    "entry": "Phlix\\Plugins\\Scrobbler\\Trakt\\TraktPlugin",
    "events": [
        "phlix.playback.started",
        "phlix.playback.stopped",
        "phlix.playback.progress"
    ],
    "settings": {
        "enabled": {
            "type": "boolean",
            "default": false,
            "description": "Enable Trakt scrobbling"
        },
        "username": {
            "type": "string",
            "default": "",
            "description": "Trakt username"
        },
        "access_token": {
            "type": "string",
            "default": null,
            "secret": true,
            "managed": true,
            "description": "OAuth access token (encrypted at rest, managed automatically — never shown in the admin UI)"
        },
        "refresh_token": {
            "type": "string",
            "default": null,
            "secret": true,
            "managed": true,
            "description": "OAuth refresh token (encrypted at rest, managed automatically — never shown in the admin UI)"
        },
        "expires_at": {
            "type": "integer",
            "default": null,
            "secret": true,
            "managed": true,
            "description": "Access token expiry timestamp (managed automatically — never shown in the admin UI)"
        },
        "sync_enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable two-way watch history sync"
        },
        "sync_interval_minutes": {
            "type": "integer",
            "default": 30,
            "description": "How often to sync Trakt history to Phlix (minutes)"
        },
        "scrobble_enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable scrobbling on playback events"
        }
    }
}
